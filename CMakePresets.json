{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 (Release)",
      "inherits": "windows-x64"
    },
    {
      "name": "apple-xcode-base",
      "hidden": true,
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "xcode",
      "displayName": "Xcode (macOS, incl. AUv3)",
      "description": "Generates build/xcode/MyPlugin.xcodeproj - open it in Xcode for AUv3 development",
      "inherits": "apple-xcode-base",
      "cacheVariables": {
        "MPLUG_BUILD_AUV3": "ON"
      }
    },
    {
      "name": "ios",
      "displayName": "iOS (AUv3)",
      "description": "Generates build/ios/MyPlugin.xcodeproj targeting iOS - open it to run the AUv3 on a device/simulator",
      "inherits": "apple-xcode-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    },
    {
      "name": "visionos",
      "displayName": "visionOS (AUv3)",
      "description": "Generates build/visionos/MyPlugin.xcodeproj targeting visionOS",
      "inherits": "apple-xcode-base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "visionOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "configuration": "Release"
    },
    {
      "name": "xcode",
      "configurePreset": "xcode",
      "configuration": "Release"
    },
    {
      "name": "ios",
      "configurePreset": "ios",
      "configuration": "Release"
    },
    {
      "name": "visionos",
      "configurePreset": "visionos",
      "configuration": "Release"
    }
  ]
}
